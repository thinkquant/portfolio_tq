# Keep gcloud source-based deploys from uploading local secrets, state, and build noise.
.git
.gitignore

.env
.env.*
*.local

node_modules
dist
build
coverage
.turbo
.cache
tmp
temp
logs
*.log

.terraform
*.tfstate
*.tfstate.*
*.tfvars
*.tfplan

.firebase
firebase-debug.log
firebase-debug.*.log

.idea
.vscode
.DS_Store
Thumbs.db
.agents
.sagf
sagf_model

service-account*.json
*-service-account*.json
*-sa-key*.json
gcp-key*.json
google-credentials*.json
