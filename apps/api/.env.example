# Shared API runtime config (non-sensitive example)
APP_ENV=dev
PORT=8080
LOG_LEVEL=info
BUILD_ID=local-dev
GIT_COMMIT_SHA=dev-placeholder

# Firestore config (required for persistence)
GCP_PROJECT_ID=portfolio-tq-dev
FIRESTORE_DATABASE=default
FIRESTORE_LOCATION=us-central1

# Vertex AI location (optional override)
VERTEX_AI_LOCATION=us-central1

# CORS (dev default allows all)
CORS_ALLOWED_ORIGIN=*
