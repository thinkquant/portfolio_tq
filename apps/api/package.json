{
  "name": "@portfolio-tq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "seed:firestore:dev": "tsx scripts/seed-firestore-dev.ts",
    "typecheck": "tsc -b tsconfig.json",
    "smoke": "tsx scripts/smoke-check.ts",
    "smoke:firestore": "tsx scripts/smoke-firestore.ts",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@portfolio-tq/agents": "workspace:*",
    "@portfolio-tq/evals": "workspace:*",
    "@portfolio-tq/schemas": "workspace:*",
    "@portfolio-tq/tools": "workspace:*",
    "@portfolio-tq/types": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  }
}
